{
  "name": "@foxy.io/elements",
  "type": "module",
  "version": "0.0.0",
  "description": "Embeddable e-commerce web components by Foxy.",
  "repository": {
    "type": "git",
    "url": "https://github.com/Foxy/foxy-elements.git"
  },
  "license": "MIT",
  "module": "./dist/npm/index.js",
  "types": "./dist/npm/index.d.ts",
  "exports": {
    "./foxy-ach-field": "./dist/npm/foxy-ach-field.ts",
    "./foxy-payment-card-field": "./dist/npm/foxy-payment-card-field.ts",
    "./foxy-payment-method-selector": "./dist/npm/foxy-payment-method-selector.tsx"
  },
  "scripts": {
    "extract": "formatjs extract 'src/**/*.ts*' --ignore='**/*.d.ts' --out-file src/locales/en-US.json --id-interpolation-pattern '[sha512:contenthash:base64:6]' --format simple",
    "localdev": "storybook dev -p 6006 --no-open",
    "build:npm": "tsc -b && vite build",
    "build:cdn": "tsc -b && vite build --mode=cdn",
    "build:storybook": "storybook build",
    "prepack": "npm run build:npm"
  },
  "dependencies": {
    "@base-ui/react": "^1.1.0",
    "@formatjs/icu-messageformat-parser": "^2.11.2",
    "@foxy.io/sdk": "file:foxy.io-sdk-0.0.0.tgz",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-portal": "^1.1.10",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@stripe/react-stripe-js": "^6.0.0",
    "@stripe/stripe-js": "^9.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.536.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-intl": "^7.1.11",
    "react-svg-credit-card-payment-icons": "^5.1.2",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.1",
    "@eslint/js": "^9.30.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@formatjs/cli": "^6.7.2",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-themes": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/web-components-vite": "^10.3.5",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^24.2.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/browser": "^4.1.4",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "eslint-plugin-storybook": "^10.3.5",
    "globals": "^16.3.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "shadcn": "^3.8.5",
    "storybook": "^10.3.5",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^8.0.4",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-external": "^6.2.2",
    "vitest": "^4.1.4"
  },
  "release": {
    "branches": [
      "main",
      {
        "name": "beta",
        "prerelease": true
      }
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/npm",
      [
        "@semantic-release/github",
        {
          "successComment": false
        }
      ]
    ]
  },
  "publishConfig": {
    "access": "public"
  }
}
